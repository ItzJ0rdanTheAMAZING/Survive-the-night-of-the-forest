<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forest Survival: 99 Nights (Fully 3D Edition)</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            font-family: 'Courier New', Courier, monospace;
            user-select: none;
        }
        #canvas-container {
            width: 100vw;
            height: 100vh;
        }
        #ui {
            position: absolute;
            top: 20px;
            left: 20px;
            color: white;
            text-shadow: 3px 3px 0px #000;
            z-index: 10;
            pointer-events: none;
        }
        .bar-container {
            width: 200px;
            height: 20px;
            background: rgba(0,0,0,0.7);
            border: 3px solid #fff;
            margin-top: 5px;
            box-shadow: 5px 5px 0px #000;
        }
        #sanity-bar {
            width: 100%;
            height: 100%;
            background: #00ffcc;
            transition: width 0.1s;
        }
        #interaction-prompt {
            position: absolute;
            bottom: 20%;
            left: 50%;
            transform: translateX(-50%);
            color: yellow;
            font-size: 1.5rem;
            font-weight: bold;
            text-shadow: 3px 3px 0px #000;
            display: none;
            z-index: 10;
            pointer-events: none;
        }
        #instructions {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            text-align: center;
            background: rgba(0,0,0,0.85);
            padding: 30px;
            border-radius: 0px;
            border: 4px solid #fff;
            box-shadow: 10px 10px 0px #000;
            z-index: 10;
            cursor: pointer;
        }
        #crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 10px;
            height: 10px;
            transform: translate(-50%, -50%);
            color: white;
            font-weight: bold;
            text-shadow: 2px 2px 0px #000;
            z-index: 5;
            pointer-events: none;
        }
        .screen-overlay {
            display: none;
            position: absolute;
            top: 0; left: 0; width: 100vw; height: 100vh;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 20;
            font-size: 2rem;
            text-align: center;
        }
        #game-over { background: black; color: red; }
        #victory { background: white; color: black; }
        .restart-btn {
            padding: 10px 20px; 
            cursor: pointer; 
            font-family: monospace; 
            margin-top: 20px;
            font-size: 1rem;
            font-weight: bold;
            background: #fff;
            border: 3px solid #000;
            box-shadow: 4px 4px 0px #000;
        }
        #flash-overlay {
            position: absolute;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: white;
            opacity: 0;
            pointer-events: none;
            z-index: 15;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

    <div id="crosshair">+</div>
    <div id="interaction-prompt">Press E to Open Chest</div>
    <div id="flash-overlay"></div>

    <div id="instructions">
        <h1>SURVIVE & SEARCH 3D</h1>
        <p>Click anywhere to look around and start.</p>
        <p><strong>WASD</strong> to Move | <strong>Mouse</strong> to Look</p>
        <p>Find the hidden 3D chests. One contains a <strong>Nuke</strong>.</p>
        <p style="color: #ff6666; font-weight: bold;">Run from 3D Bobby.</p>
    </div>

    <div id="ui">
        <div id="day-counter">Night: 1/99</div>
        <div id="time-of-day">Time: Evening</div>
        <div style="margin-top: 10px;">Sanity:</div>
        <div class="bar-container">
            <div id="sanity-bar"></div>
        </div>
        <div id="chest-alert" style="margin-top: 15px; color: #ffcc00; font-weight: bold;"></div>
    </div>

    <!-- Game End Screens -->
    <div id="game-over" class="screen-overlay">
        <h1>YOU LOST YOUR SANITY</h1>
        <p style="font-size: 1.2rem; color: white;">Bobby caught up to you.</p>
        <button class="restart-btn" onclick="location.reload()">Try Again</button>
    </div>

    <div id="victory" class="screen-overlay">
        <h1 style="color: #d32f2f; font-size: 3.5rem; margin: 0; text-shadow: 4px 4px 0px #000;">TACTICAL NUKE DETONATED</h1>
        <p style="font-size: 1.5rem; font-weight: bold; margin-top: 10px;">The Forest is Gone. Bobby is gone. You Win!</p>
        <button class="restart-btn" onclick="location.reload()" style="background: black; color: white; border: 3px solid white; box-shadow: 4px 4px 0px #999;">Play Again</button>
    </div>

    <div id="canvas-container"></div>

    <script>
        // --- Game Variables ---
        let scene, camera, renderer;
        let moveForward = false, moveBackward = false, moveLeft = false, moveRight = false;
        let prevTime = performance.now();
        const velocity = new THREE.Vector3();
        const direction = new THREE.Vector3();
        
        let sanity = 100;
        let nightCounter = 1;
        let timeOfDay = 0; 
        let isGameOver = false;
        let isNuking = false;
        let nukeTimer = 0;

        let ambientLight, hemiLight, flashlight;
        let chests = [];
        let activeChest = null; 

        // Monster (Bobby) variables
        let bobby;
        let bobbyName3D;
        const bobbySpeed = 16;
        const bobbyAttackRange = 5.5;

        const cameraRotation = { x: 0, y: 0 };
        const instructions = document.getElementById('instructions');
        const canvasContainer = document.getElementById('canvas-container');
        const promptUI = document.getElementById('interaction-prompt');
        const alertUI = document.getElementById('chest-alert');
        const flashOverlay = document.getElementById('flash-overlay');

        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x0b1d1a);
            scene.fog = new THREE.FogExp2(0x0b1d1a, 0.05);

            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.y = 2; 

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            canvasContainer.appendChild(renderer.domElement);

            // Lighting
            ambientLight = new THREE.AmbientLight(0xffffff, 0.2);
            scene.add(ambientLight);

            hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 0.4);
            hemiLight.position.set(0, 200, 0);
            scene.add(hemiLight);

            flashlight = new THREE.SpotLight(0xfffadb, 2.5, 50, Math.PI / 4, 0.5, 1);
            flashlight.castShadow = true;
            camera.add(flashlight);
            flashlight.position.set(0, 0, 0);
            flashlight.target.position.set(0, 0, -1);
            camera.add(flashlight.target);
            scene.add(camera);

            // Build Environment
            createGround();
            createForest();
            createChests();
            createBobby();

            // Event Listeners
            document.addEventListener('keydown', onKeyDown);
            document.addEventListener('keyup', onKeyUp);
            instructions.addEventListener('click', () => canvasContainer.requestPointerLock());

            document.addEventListener('pointerlockchange', () => {
                if (document.pointerLockElement === canvasContainer) {
                    instructions.style.display = 'none';
                } else {
                    if(!isGameOver && !isNuking) instructions.style.display = 'block';
                }
            });

            document.addEventListener('mousemove', onMouseMove);
            window.addEventListener('resize', onWindowResize);

            animate();
        }

        function createGround() {
            const floorGeo = new THREE.PlaneGeometry(1000, 1000);
            const floorMat = new THREE.MeshStandardMaterial({ color: 0x112211, roughness: 0.9 });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.rotation.x = -Math.PI / 2;
            floor.receiveShadow = true;
            scene.add(floor);
        }

        function createForest() {
            const trunkGeo = new THREE.CylinderGeometry(0.2, 0.4, 5, 8);
            const trunkMat = new THREE.MeshStandardMaterial({ color: 0x4a2f13 });
            const leavesGeo = new THREE.ConeGeometry(2, 6, 8);
            const leavesMat = new THREE.MeshStandardMaterial({ color: 0x133a1b, roughness: 0.6 });

            for (let i = 0; i < 400; i++) {
                const tree = new THREE.Group();
                const trunk = new THREE.Mesh(trunkGeo, trunkMat);
                trunk.position.y = 2.5;
                tree.add(trunk);

                const leaves = new THREE.Mesh(leavesGeo, leavesMat);
                leaves.position.y = 5.5;
                tree.add(leaves);

                const x = (Math.random() - 0.5) * 350;
                const z = (Math.random() - 0.5) * 350;
                if (Math.sqrt(x*x + z*z) < 15) continue; 

                tree.position.set(x, 0, z);
                scene.add(tree);
            }
        }

        function createChests() {
            const totalChests = 50;
            const nukeChestIndex = Math.floor(Math.random() * totalChests);

            const boxGeo = new THREE.BoxGeometry(1.2, 0.8, 0.8);
            const boxMat = new THREE.MeshStandardMaterial({ color: 0x6e4720, roughness: 0.7 }); 
            const ironTrimMat = new THREE.MeshStandardMaterial({ color: 0x444444, metalness: 0.8 });

            for (let i = 0; i < totalChests; i++) {
                const chestGroup = new THREE.Group();
                
                const box = new THREE.Mesh(boxGeo, boxMat);
                box.position.y = 0.4;
                box.castShadow = true;
                chestGroup.add(box);

                const lockGeo = new THREE.BoxGeometry(0.2, 0.2, 0.1);
                const lock = new THREE.Mesh(lockGeo, ironTrimMat);
                lock.position.set(0, 0.4, 0.41);
                chestGroup.add(lock);

                const x = (Math.random() - 0.5) * 350;
                const z = (Math.random() - 0.5) * 350;
                if (Math.sqrt(x*x + z*z) < 20) { i--; continue; } 

                chestGroup.position.set(x, 0, z);
                chestGroup.rotation.y = Math.random() * Math.PI * 2;

                chestGroup.userData = {
                    id: i,
                    hasNuke: (i === nukeChestIndex),
                    opened: false
                };

                scene.add(chestGroup);
                chests.push(chestGroup);
            }
        }

        function createBobby() {
            bobby = new THREE.Group();
            // Using a standard material that reacts to lights/flashlights for full 3D shadow rendering
            const mat = new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.8 }); 

            // --- 1. FULLY 3D STICKMAN MODEL ---
            // Head (3D Sphere)
            const headGeo = new THREE.SphereGeometry(0.35, 16, 16);
            const head = new THREE.Mesh(headGeo, mat);
            head.position.y = 2.8;
            head.castShadow = true;
            bobby.add(head);

            // Torso (3D Cylinder thickness)
            const torsoGeo = new THREE.CylinderGeometry(0.08, 0.08, 1.3, 8);
            const torso = new THREE.Mesh(torsoGeo, mat);
            torso.position.y = 1.95;
            torso.castShadow = true;
            bobby.add(torso);

            // Left Arm (3D Cylinder block)
            const armGeo = new THREE.CylinderGeometry(0.06, 0.06, 1.1, 8);
            const armL = new THREE.Mesh(armGeo, mat);
            armL.position.set(-0.4, 2.1, 0);
            armL.rotation.z = Math.PI / 3.5;
            armL.castShadow = true;
            bobby.add(armL);

            // Right Arm (3D Cylinder block)
            const armR = new THREE.Mesh(armGeo, mat);
            armR.position.set(0.4, 2.1, 0);
            armR.rotation.z = -Math.PI / 3.5;
            armR.castShadow = true;
            bobby.add(armR);

            // Left Leg (3D Cylinder block)
            const legGeo = new THREE.CylinderGeometry(0.08, 0.08, 1.4, 8);
            const legL = new THREE.Mesh(legGeo, mat);
            legL.position.set(-0.25, 0.7, 0);
            legL.rotation.z = 0.12;
            legL.castShadow = true;
            bobby.add(legL);

            // Right Leg (3D Cylinder block)
            const legR = new THREE.Mesh(legGeo, mat);
            legR.position.set(0.25, 0.7, 0);
            legR.rotation.z = -0.12;
            legR.castShadow = true;
            bobby.add(legR);

            // Spawn Bobby off out in the grid
            bobby.position.set(120, 0, 120);
            scene.add(bobby);

            // --- 2. FULLY 3D TEXT NAME TAG ---
            // Render text to high-res canvas, map onto a distinct structural 3D plane mesh
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = 512;
            canvas.height = 128;
            
            // Text stroke box background
            ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';
            ctx.fillRect(32, 16, 448, 96);
            ctx.lineWidth = 6;
            ctx.strokeStyle = 'red';
            ctx.strokeRect(32, 16, 448, 96);
            
            // Text settings
            ctx.font = 'Bold 64px Courier New';
            ctx.fillStyle = 'red';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('BOBBY', canvas.width / 2, canvas.height / 2);

            const textTexture = new THREE.CanvasTexture(canvas);
            const textPlaneGeo = new THREE.PlaneGeometry(3.5, 0.875);
            const textPlaneMat = new THREE.MeshBasicMaterial({ 
                map: textTexture, 
                transparent: true,
                side: THREE.DoubleSide
            });
            
            bobbyName3D = new THREE.Mesh(textPlaneGeo, textPlaneMat);
            bobbyName3D.position.y = 3.6; // Clear height above his 3D sphere head
            bobby.add(bobbyName3D);
        }

        function onMouseMove(event) {
            if (document.pointerLockElement !== canvasContainer) return;
            cameraRotation.y -= (event.movementX || 0) * 0.002;
            cameraRotation.x -= (event.movementY || 0) * 0.002;
            cameraRotation.x = Math.max(-Math.PI / 2.5, Math.min(Math.PI / 2.5, cameraRotation.x));
            camera.quaternion.setFromEuler(new THREE.Euler(cameraRotation.x, cameraRotation.y, 0, 'YXZ'));
        }

        function onKeyDown(event) {
            if (isGameOver || isNuking) return;
            switch (event.code) {
                case 'KeyW': moveForward = true; break;
                case 'KeyA': moveLeft = true; break;
                case 'KeyS': moveBackward = true; break;
                case 'KeyD': moveRight = true; break;
                case 'KeyE': tryOpenChest(); break;
            }
        }

        function onKeyUp(event) {
            switch (event.code) {
                case 'KeyW': moveForward = false; break;
                case 'KeyA': moveLeft = false; break;
                case 'KeyS': moveBackward = false; break;
                case 'KeyD': moveRight = false; break;
            }
        }

        function tryOpenChest() {
            if (activeChest && !activeChest.userData.opened) {
                activeChest.userData.opened = true;
                
                activeChest.children[0].scale.y = 0.5; 
                activeChest.children[0].position.y = 0.2; 

                if (activeChest.userData.hasNuke) {
                    triggerNukeEvent();
                } else {
                    alertUI.innerText = "Empty chest... keep looking!";
                    setTimeout(() => { alertUI.innerText = ""; }, 3000);
                }
            }
        }

        function triggerNukeEvent() {
            isNuking = true;
            document.exitPointerLock();
            alertUI.style.color = "red";
            alertUI.style.fontSize = "1.5rem";
            alertUI.innerText = "💥 NUKE FOUND! DETONATION IMMINENT! 💥";
        }

        function checkChestInteractions() {
            if (isGameOver || isNuking) {
                promptUI.style.display = 'none';
                return;
            }

            let closestChest = null;
            let minDistance = 5; 

            const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);

            for (let chest of chests) {
                const dist = camera.position.distanceTo(chest.position);
                if (dist < minDistance) {
                    const toChest = chest.position.clone().sub(camera.position).normalize();
                    const dot = forward.dot(toChest);

                    if (dot > 0.85 && !chest.userData.opened) { 
                        closestChest = chest;
                        break;
                    }
                }
            }

            if (closestChest) {
                activeChest = closestChest;
                promptUI.style.display = 'block';
            } else {
                activeChest = null;
                promptUI.style.display = 'none';
            }
        }

        function updateBobby(delta) {
            if (isGameOver || isNuking) return;

            // 1. Core tracking system
            const playerPos = new THREE.Vector3(camera.position.x, 0, camera.position.z);
            bobby.lookAt(playerPos); 

            const direction = playerPos.clone().sub(bobby.position).normalize();
            bobby.position.addScaledVector(direction, bobbySpeed * delta);

            // 2. 3D Nameplate Face Rotation Target Logic
            // Rotates the structural 3D object plane surface dynamically towards you
            bobbyName3D.lookAt(camera.position);

            // 3. Radius Collision check
            const distance = bobby.position.distanceTo(playerPos);
            if (distance < bobbyAttackRange) {
                sanity -= delta * 55; 
                ambientLight.color.setHex(0xffaaaa);
                
                if (!alertUI.innerText) {
                    alertUI.style.color = "red";
                    alertUI.innerText = "Bobby is consuming your sanity!";
                    setTimeout(() => { 
                        if(!isGameOver) alertUI.innerText = ""; 
                        ambientLight.color.setHex(0xffffff);
                    }, 1000);
                }
            }
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);

            const time = performance.now();
            const delta = (time - prevTime) / 1000;
            prevTime = time;

            if (isNuking) {
                runNukeCutscene(delta);
                return;
            }

            if (isGameOver) return;

            handleMovement(delta);
            handleSurvivalCycle(delta);
            checkChestInteractions();
            updateBobby(delta); 

            renderer.render(scene, camera);
        }

        function handleMovement(delta) {
            velocity.x -= velocity.x * 10.0 * delta;
            velocity.z -= velocity.z * 10.0 * delta;

            direction.z = Number(moveForward) - Number(moveBackward);
            direction.x = Number(moveRight) - Number(moveLeft);
            direction.normalize(); 

            const camEuler = new THREE.Euler(0, cameraRotation.y, 0, 'YXZ');
            const moveDirection = new THREE.Vector3(direction.x, 0, -direction.z).applyEuler(camEuler);

            if (moveForward || moveBackward) velocity.z -= moveDirection.z * 100.0 * delta;
            if (moveLeft || moveRight) velocity.x += moveDirection.x * 100.0 * delta;

            camera.position.addScaledVector(velocity, delta);

            camera.position.x = Math.max(-175, Math.min(175, camera.position.x));
            camera.position.z = Math.max(-175, Math.min(175, camera.position.z));
        }

        function handleSurvivalCycle(delta) {
            timeOfDay += delta * 1.5; 
            if (timeOfDay >= 100) {
                timeOfDay = 0;
                nightCounter++;
                document.getElementById('day-counter').innerText = `Night: ${nightCounter}/99`;
            }

            if (timeOfDay > 30 && timeOfDay < 70) {
                document.getElementById('time-of-day').innerText = "Time: Midnight";
                scene.background.setHex(0x010202);
                scene.fog.color.setHex(0x010202);
                hemiLight.intensity = 0.01;
                flashlight.intensity = 4.5;
                sanity -= delta * 2.5; 
            } else {
                document.getElementById('time-of-day').innerText = "Time: Twilight";
                scene.background.setHex(0x0b1d1a);
                scene.fog.color.setHex(0x0b1d1a);
                hemiLight.intensity = 0.3;
                flashlight.intensity = 0.5;
                if (sanity < 100) sanity += delta * 3.0;
            }

            sanity = Math.max(0, Math.min(100, sanity));
            document.getElementById('sanity-bar').style.width = sanity + '%';

            if (sanity <= 0) {
                isGameOver = true;
                document.exitPointerLock();
                document.getElementById('game-over').style.display = 'flex';
            }
        }

        function runNukeCutscene(delta) {
            nukeTimer += delta;

            if (nukeTimer < 3) {
                camera.position.x += (Math.random() - 0.5) * 0.25;
                camera.position.y += (Math.random() - 0.5) * 0.25;
                camera.position.z += (Math.random() - 0.5) * 0.25;
                
                ambientLight.intensity += delta * 25;
                bobby.visible = false; 
                renderer.render(scene, camera);
            } 
            else if (nukeTimer >= 3 && nukeTimer < 4.5) {
                flashOverlay.style.opacity = (nukeTimer - 3) / 1.5;
            } 
            else {
                document.getElementById('victory').style.display = 'flex';
            }
        }

        window.onload = init;
    </script>
</body>
</html>